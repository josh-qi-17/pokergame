{
  "name": "poker-game",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"pnpm --filter @poker/server dev\" \"pnpm --filter @poker/web dev\"",
    "build": "pnpm --filter @poker/shared build && pnpm --filter @poker/engine build && pnpm --filter @poker/server build && pnpm --filter @poker/web build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "start": "pnpm --filter @poker/server start"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
