{
  "name": "@poker/server",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && prisma generate",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@poker/engine": "workspace:*",
    "@poker/shared": "workspace:*",
    "@prisma/client": "^5.15.0",
    "async-mutex": "^0.5.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.0",
    "nanoid": "^5.0.7",
    "pino": "^9.3.1",
    "pino-pretty": "^11.2.1",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "prisma": "^5.15.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
