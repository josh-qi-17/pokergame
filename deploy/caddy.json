{
  "apps": {
    "http": {
      "servers": {
        "poker": {
          "listen": [":443"],
          "routes": [
            {
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [{"dial": "localhost:3001"}],
                  "transport": {
                    "protocol": "http",
                    "dial_timeout": "10s"
                  }
                }
              ]
            }
          ],
          "tls_connection_policies": [
            {
              "match": {"sni": ["your-domain.com"]}
            }
          ]
        }
      }
    },
    "tls": {
      "automation": {
        "policies": [
          {
            "subjects": ["your-domain.com"],
            "issuers": [{"module": "acme"}]
          }
        ]
      }
    }
  }
}
